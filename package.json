{
  "name": "baileys",
  "version": "0.0.1",
  "type": "module",
  "description": "Personal Baileys fork — @whiskeysockets/baileys v7.0.0-rc13 TypeScript source with extended message types",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./WAProto": {
      "types": "./WAProto/index.d.ts",
      "import": "./WAProto/index.js"
    }
  },
  "files": [
    "dist",
    "WAProto",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cacheable/node-cache": "^1.4.0",
    "@hapi/boom": "^10.0.0",
    "async-mutex": "^0.5.0",
    "libphonenumber-js": "^1.10.20",
    "libsignal": "^6.0.0",
    "link-preview-js": "^3.0.0",
    "long": "^5.2.3",
    "lru-cache": "^11.1.0",
    "music-metadata": "^11.12.3",
    "p-queue": "^9.0.0",
    "pino": "^10.0.0",
    "protobufjs": "^7.5.6",
    "whatsapp-rust-bridge": "0.5.4",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@types/ws": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.8.2"
  },
  "peerDependencies": {
    "jimp": "^1.6.1",
    "sharp": "^0.33.0"
  },
  "peerDependenciesMeta": {
    "jimp": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
